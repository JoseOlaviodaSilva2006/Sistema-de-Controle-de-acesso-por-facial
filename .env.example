# Configuração de Segurança - AURA ACCESS CONTROL
# Não compartilhe este arquivo em repositórios públicos!

# Admin inicial (usado apenas no primeiro setup)
DEFAULT_ADMIN_USER=admin
DEFAULT_ADMIN_PASSWORD=admin123

# Limiares biométricos
CONFIDENCE_THRESHOLD=95.0
REQUIRED_SAMPLES=100
REQUIRED_CONSISTENT_MATCHES=3

# Caminhos
DB_PATH=access_control_v2.db
MODEL_PATH=data/lbph_model.yml
CASCADE_PATH=data/haarcascade_frontalface_alt.xml
